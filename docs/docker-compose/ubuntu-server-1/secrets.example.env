# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================================
# Keepalived (VRRP Authentication)
# ============================================================
KEEPALIVED_AUTH_HTTP=XXXXXXXX            # VRRP HTTP group auth password
KEEPALIVED_AUTH_VPN_DNS=XXXXXXXX         # VRRP VPN-DNS group auth password

# ============================================================
# Nginx Proxy Manager (MariaDB)
# ============================================================
NPM_MYSQL_ROOT_PASSWORD=XXXXXXXX
NPM_MYSQL_PASSWORD=XXXXXXXX

# ============================================================
# Pi-Hole
# ============================================================
PIHOLE_WEBPASSWORD=XXXXXXXX              # Pi-Hole admin password

# ============================================================
# Vaultwarden
# ============================================================
VAULTWARDEN_ADMIN_TOKEN=XXXXXXXX          # Optional: admin panel token
VAULTWARDEN_PUSH_INSTALLATION_ID=XXXXXXXX # From bitwarden.com/host

# ============================================================
# Cloudflare DDNS
# ============================================================
CF_API_TOKEN=XXXXXXXX                    # Cloudflare API token

# ============================================================
# Nebula Sync (Pi-Hole replication)
# ============================================================
# Format: https://PIHOLE_HOST:PORT|PASSWORD
NEBULA_SYNC_PRIMARY=https://192.168.2.200:8443|XXXXXXXX
NEBULA_SYNC_REPLICAS=https://192.168.2.201:5443|XXXXXXXX,https://192.168.2.205:8443|XXXXXXXX

# ============================================================
# LinkStack
# ============================================================
LINKSTACK_SERVER_NAME=your-domain.com

# ============================================================
# Grafana
# ============================================================
GF_ADMIN_PASSWORD=XXXXXXXX
GF_SECRET_KEY=XXXXXXXX