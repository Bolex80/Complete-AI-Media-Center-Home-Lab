# Secrets template for Ubuntu Server 1 (Bentomo_Net)
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# === Pi-Hole ===
PIHOLE_PASSWORD=changeme        # Web admin password for Pi-Hole

# === Vaultwarden ===
VW_ADMIN_TOKEN=changeme        # Admin panel token
VW_DOMAIN=https://pass.benthem.es

# === Cloudflare DDNS ===
CF_API_TOKEN=changeme           # Cloudflare API token
CF_DOMAINS=bentomo.es,bolex.es  # Domains to update

# === NUT (Network UPS Tools) ===
NUT_USER=changeme              # UPS daemon user
NUT_PASS=changeme              # UPS daemon password

# === Nebula Sync ===
# Uses same PIHOLE_PASSWORD as above

# === Beszel ===
BESZEL_KEY=changeme            # SSH public key from Beszel hub