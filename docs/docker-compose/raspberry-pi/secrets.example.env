# Raspberry Pi Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================================
# Keepalived (VRRP Authentication)
# ============================================================
KEEPALIVED_AUTH_HTTP=XXXXXXXX            # VRRP HTTP group auth password
KEEPALIVED_AUTH_VPN_DNS=XXXXXXXX         # VRRP VPN-DNS group auth password

# ============================================================
# Nginx Proxy Manager (MariaDB)
# ============================================================
NPM_MYSQL_ROOT_PASSWORD=XXXXXXXX
NPM_MYSQL_PASSWORD=XXXXXXXX

# ============================================================
# Vaultwarden
# ============================================================
VAULTWARDEN_ADMIN_TOKEN=XXXXXXXX          # Optional: admin panel token
VAULTWARDEN_DOMAIN=https://pass.benthem.es
VAULTWARDEN_PUSH_INSTALLATION_ID=XXXXXXXX  # Optional: from bitwarden.com/host

# ============================================================
# Cloudflare DDNS
# ============================================================
CF_API_TOKEN=XXXXXXXX                    # Cloudflare API token

# ============================================================
# WatchYourLAN
# ============================================================
WYL_AUTH_USER=XXXXXXXX                  # ForAuth username

# ============================================================
# Beszel Agent
# ============================================================
BESZEL_KEY=XXXXXXXX                     # SSH key from Beszel hub installation